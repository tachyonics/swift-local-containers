# Copy this file to `.local-containers/env` and fill in values.
# Real environment variables always take precedence over values here.
#
# Syntax: KEY=VALUE, one per line. Blank lines and `#` comments ignored.
# Surrounding single or double quotes are stripped from values.

# LocalStack auth token — required for LocalStack to start.
# Get one at https://app.localstack.cloud/settings/auth-tokens
# LOCALSTACK_AUTH_TOKEN=your-token-here
