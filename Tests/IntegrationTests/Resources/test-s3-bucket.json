{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Integration test template — creates an S3 bucket.",
  "Resources": {
    "TestBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": "integration-test-bucket"
      }
    }
  },
  "Outputs": {
    "BucketName": {
      "Description": "Name of the S3 bucket",
      "Value": { "Ref": "TestBucket" }
    }
  }
}
